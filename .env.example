# Copy this file to ".env" and fill in your values, then restart `npm run dev`.

# --- Admin passcode -------------------------------------------------------
# Scorekeepers enter this code (top-right "Admin" button) to edit scores.
# If omitted, the default is "levelup".
VITE_ADMIN_PASSCODE=levelup

# --- Firebase (optional) --------------------------------------------------
# Leave these blank to run in local demo mode (data stored in the browser,
# synced across tabs). Fill them in to go LIVE across all devices in real time.
# Get these values from the Firebase console:
#   Project settings → General → Your apps → SDK setup and configuration.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
